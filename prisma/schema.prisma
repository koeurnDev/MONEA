generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  name              String?
  email             String    @unique
  password          String
  role              String    @default("ADMIN") // PLATFORM_OWNER (SUPERADMIN), EVENT_MANAGER (ADMIN), EVENT_STAFF (STAFF)
  twoFactorSecret   String?
  twoFactorEnabled  Boolean   @default(false)
  twoFactorRecoveryCodes String?
  failedAttempts    Int       @default(0)
  lockedUntil       DateTime?
  sessionsRevokedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  weddings          Wedding[]
  supportTickets    SupportTicket[]
}

model Wedding {
  id               String           @id @default(cuid())
  groomName        String
  brideName        String
  location         String?
  date             DateTime
  eventType        String           @default("wedding") // wedding, anniversary
  templateId       String           @default("classic")
  themeSettings    String? // Stores: { primaryColor, musicUrl, mapLink, videoUrl, heroImage }
  notes            String? // Internal organizer notes
  weddingCode      String?          @unique
  status           String           @default("ACTIVE") // ACTIVE, ARCHIVED
  packageType      String           @default("FREE") // FREE, PRO, PREMIUM
  paymentStatus    String           @default("PENDING") // PENDING, PAID
  expiresAt        DateTime?
  userId           String
  user             User             @relation(fields: [userId], references: [id])
  guests           Guest[]
  gifts            Gift[]
  telegramLink     String?
  paymentInfo      String?
  galleryItems     GalleryItem[]
  guestbookEntries GuestbookEntry[]
  activities       Activity[]
  staff            Staff[]
  logs             Log[]
  supportTickets   SupportTicket[]
  templateVersions WeddingTemplateVersion[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @default(now()) @updatedAt

  @@index([userId])
  @@index([status])
}

model Activity {
  id          String   @id @default(cuid())
  title       String
  time        String // e.g. "07:00 AM"
  description String?
  order       Int      @default(0) // For sorting
  weddingId   String
  wedding     Wedding  @relation(fields: [weddingId], references: [id])
  createdAt   DateTime @default(now())

  @@index([weddingId])
}

model Guest {
  id         String    @id @default(cuid())
  name       String
  phone      String?
  group      String?
  source     String? // e.g. Phnom Penh, Prey Veng
  weddingId  String
  wedding    Wedding   @relation(fields: [weddingId], references: [id])
  gifts      Gift[]
  hasArrived Boolean   @default(false)
  arrivedAt  DateTime?
  views      Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now()) @updatedAt

  @@index([weddingId])
  @@index([hasArrived])
}

model Gift {
  id        String   @id @default(cuid())
  amount    Float
  currency  String // USD, KHR
  method    String? // Cash, ABA, Wing
  weddingId String
  wedding   Wedding  @relation(fields: [weddingId], references: [id])
  guestId   String?
  guest     Guest?   @relation(fields: [guestId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([weddingId])
  @@index([guestId])
  @@index([method])
  @@index([currency])
}

model GalleryItem {
  id        String   @id @default(cuid())
  url       String
  type      String // IMAGE, VIDEO
  caption   String?
  weddingId String
  wedding   Wedding  @relation(fields: [weddingId], references: [id])
  createdAt DateTime @default(now())

  @@index([weddingId])
}

model GuestbookEntry {
  id        String   @id @default(cuid())
  guestName String
  message   String
  voiceUrl  String?
  weddingId String
  wedding   Wedding  @relation(fields: [weddingId], references: [id])
  createdAt DateTime @default(now())

  @@index([weddingId])
}

model Staff {
  id                String    @id @default(cuid())
  name              String
  email             String?   @unique
  password          String?
  pin               String?
  role              String    @default("STAFF") // SCANNER, CASHIER
  weddingId         String
  wedding           Wedding   @relation(fields: [weddingId], references: [id])
  accessToken       String?   @unique
  twoFactorSecret   String?
  twoFactorEnabled  Boolean   @default(false)
  twoFactorRecoveryCodes String?
  failedAttempts    Int       @default(0)
  lockedUntil       DateTime?
  sessionsRevokedAt DateTime?
  createdAt         DateTime  @default(now())

  @@index([weddingId])
}

model Log {
  id          String   @id @default(cuid())
  action      String // CHECK_IN, GIFT, UPDATE
  description String
  actorName   String // Staff Name or User
  ip          String?
  userAgent   String?
  weddingId   String
  wedding     Wedding  @relation(fields: [weddingId], references: [id])
  createdAt   DateTime @default(now())

  @@index([weddingId])
}

model BlacklistedIP {
  id        String   @id @default(cuid())
  ip        String   @unique
  reason    String?
  createdAt DateTime @default(now())
}

model IpSecurity {
  id           String    @id @default(cuid())
  ip           String    @unique
  failures     Int       @default(0)
  blockedUntil DateTime?
  lastAttempt  DateTime  @updatedAt
}

model SecurityLog {
  id        String   @id @default(cuid())
  event     String   // e.g., "LOGIN_FAILED", "LOGIN_SUCCESS", "RATE_LIMIT_EXCEEDED"
  ip        String
  geoIp     String?  // e.g., "KH", "US"
  userAgent String?
  email     String?
  details   String?
  createdAt DateTime @default(now())

  @@index([event])
  @@index([createdAt])
  @@index([ip])
  @@index([email])
}

model SystemConfig {
  id              String   @id @default("GLOBAL")
  maintenanceMode Boolean  @default(false)
  allowNewSignups Boolean  @default(true)
  globalCheckIn   Boolean  @default(true) // Master kill switch for all check-ins
  updatedAt       DateTime @updatedAt
}

model Broadcast {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("INFO") // INFO, WARNING, SUCCESS
  active    Boolean  @default(true)
  expiresAt DateTime?
  createdAt DateTime @default(now())
}

model SupportTicket {
  id          String   @id @default(cuid())
  subject     String
  message     String
  status      String   @default("OPEN") // OPEN, CLOSED, PENDING
  priority    String   @default("NORMAL")
  weddingId   String
  wedding     Wedding  @relation(fields: [weddingId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([weddingId])
  @@index([userId])
}

model SystemVersion {
  id          String   @id @default(cuid())
  versionName String // e.g., "v1.0.4", "Stable Release"
  configData  String // JSON snapshot of SystemConfig
  description String?
  isStable    Boolean  @default(false)
  createdBy   String
  createdAt   DateTime @default(now())
}

model GovernanceLog {
  id          String   @id @default(cuid())
  action      String // PUBLISH, ROLLBACK, CONFIG_UPDATE
  details     String // JSON details
  actorId     String
  actorName   String
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([actorId])
}

model WeddingTemplateVersion {
  id           String   @id @default(cuid())
  weddingId    String
  wedding      Wedding  @relation(fields: [weddingId], references: [id])
  versionName  String   // e.g. "Before color change", "v1.2"
  templateId   String   // snapshot of templateId
  themeData    String   // JSON snapshot of themeSettings
  description  String?
  createdBy    String
  createdAt    DateTime @default(now())

  @@index([weddingId])
}

model DailySecuritySummary {
  id             String   @id @default(cuid())
  date           DateTime @unique
  totalLogins    Int
  failedAttempts Int
  blockedIps     Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
